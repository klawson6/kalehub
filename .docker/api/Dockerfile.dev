FROM node:24-alpine AS base
RUN apk add --no-cache python3 make g++
RUN corepack enable && corepack prepare pnpm@11.3.0 --activate
WORKDIR /app

# Copy manifests for workspace resolution (source is bind-mounted at runtime)
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml tsconfig.base.json ./
COPY packages/types/package.json ./packages/types/
COPY packages/types/tsconfig.json ./packages/types/
COPY packages/db/package.json ./packages/db/
COPY packages/db/tsconfig.json ./packages/db/
COPY packages/db/prisma ./packages/db/prisma
COPY apps/api/package.json ./apps/api/

RUN pnpm install --frozen-lockfile

# Source directories are bind-mounted via docker-compose.override.yml
ENV PORT=3001
EXPOSE 3001

CMD ["sh", "-c", "pnpm --filter @kalehub/types build && pnpm --filter @kalehub/db build && pnpm --filter api dev"]
