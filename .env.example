# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=kalehub
POSTGRES_PASSWORD=changeme
POSTGRES_DB=kalehub_dev
POSTGRES_DB_KEYCLOAK=keycloak

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_CLIENT_ID=kalehub
# Dev value matches keycloak/realm-export.json; change in production
KEYCLOAK_CLIENT_SECRET=dev-secret-changeme-in-env
# External URL — used by the browser for the OAuth redirect and iss verification
KEYCLOAK_ISSUER=http://localhost:8080/realms/kalehub
# Internal Docker URL — used by Auth.js for server-side token exchange (web container only)
# When running web natively (not in Docker), leave this unset; it falls back to KEYCLOAK_ISSUER
KEYCLOAK_INTERNAL_URL=http://keycloak:8080/realms/kalehub

# ─── Auth (shared by web, api, ws — must match exactly) ───────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=changeme

# ─── Service URLs ─────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3002

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Database (used by api + packages/db) ─────────────────────────────────────
DATABASE_URL=postgresql://kalehub:changeme@localhost:5432/kalehub_dev
